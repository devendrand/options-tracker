# Options Tracker — Environment Variables
# Copy this file to .env before running docker compose:
#   cp .env.example .env
#
# .env is gitignored. Never commit .env with real credentials.

# PostgreSQL
POSTGRES_USER=options_tracker
POSTGRES_PASSWORD=options_tracker_dev
POSTGRES_DB=options_tracker

# Backend database connection (used by FastAPI via SQLAlchemy asyncpg)
DATABASE_URL=postgresql+asyncpg://options_tracker:options_tracker_dev@db:5432/options_tracker

# Application
LOG_LEVEL=INFO
BACKEND_PORT=8000
FRONTEND_PORT=4200
