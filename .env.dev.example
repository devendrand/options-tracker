POSTGRES_USER=options_tracker
POSTGRES_PASSWORD=options_tracker_dev
POSTGRES_DB=options_tracker_dev

DATABASE_URL=postgresql+asyncpg://options_tracker:options_tracker_dev@db:5432/options_tracker_dev

LOG_LEVEL=DEBUG
BACKEND_PORT=8000
FRONTEND_PORT=4200
DB_PORT=5432
